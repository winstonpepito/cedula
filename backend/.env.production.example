APP_NAME=eCedula
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ecedula.com
FRONTEND_URL=https://ecedula.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecedula
DB_USERNAME=ecedula
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.ecedula.com
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=ecedula.com,www.ecedula.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ecedula.com"
MAIL_FROM_NAME="${APP_NAME}"

PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_ENABLED=false
